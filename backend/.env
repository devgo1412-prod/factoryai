# backend/.env.example  →  복사 후 .env 로 저장

# ── LLM 서버 ──────────────────────────────────
LLM_API_BASE_URL=http://192.168.0.74:11434/v1
#   Ollama   : http://192.168.1.100:11434/v1
#   vLLM     : http://192.168.1.100:8000/v1
#   LM Studio: http://192.168.1.100:1234/v1

LLM_API_KEY=ollama
LLM_MODEL_NAME=qwen3.5:35b
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=120

# ── 임베딩 / 벡터DB ───────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHROMA_DIR=./chroma

# ── MSSQL ─────────────────────────────────────
DB_SERVER=192.168.0.11
DB_NAME=PrismDB
DB_USER=prismadm
DB_PASSWORD=prism@2025
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_TRUSTED=false
