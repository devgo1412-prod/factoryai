# backend/.env.example  →  복사 후 .env 로 저장

# ── LLM 서버 ──────────────────────────────────
LLM_API_BASE_URL=http://YOUR_SERVER_IP:11434/v1
LLM_API_KEY=ollama
LLM_MODEL_NAME=llama3
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=120

# ── 임베딩 / 벡터DB ───────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHROMA_DIR=./chroma

# ── MSSQL ─────────────────────────────────────
DB_SERVER=localhost
DB_NAME=YourDB
DB_USER=sa
DB_PASSWORD=yourpassword
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_TRUSTED=false
